# Discourse (cax.do) — DiscourseConnect Provider
DISCOURSE_URL=https://cax.do
# 与论坛后台 discourse_connect_provider_secrets 中 mechbox.cax.do| 后面的密钥一致
DISCOURSE_SSO_SECRET=change-me-to-a-long-random-string

# MechBox 对外访问地址（生产环境）
MECHBOX_PUBLIC_URL=https://mechbox.cax.do

# Session 签名密钥（随机字符串，≥16 字符）
SESSION_SECRET=change-me-session-secret

# Auth API 端口（Nginx 反代到此处）
AUTH_PORT=3001

# 生产环境设为 production；本地开发可设 development
NODE_ENV=development

# 本地 HTTPS 调试时可设 false
# COOKIE_SECURE=false
